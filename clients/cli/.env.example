# OpenAI API key (required when using --descriptions)
OPENAI_API_KEY=sk-...

# Optional: override the base URL for any OpenAI-compatible endpoint
# Examples:
#   Azure OpenAI:  https://<resource>.openai.azure.com/openai/deployments/<deployment>
#   Ollama:        http://localhost:11434/v1
#   LM Studio:     http://localhost:1234/v1
# OPENAI_BASE_URL=

# Optional: model to use (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional: max number of parallel LLM requests (default: 5)
# Increase for faster enrichment, decrease to avoid rate-limit errors.
# OPENAI_CONCURRENCY=5

# Optional: max entities per LLM request (default: 20)
# Files with more entities are split into multiple requests.
# Decrease if you see truncated JSON errors.
# OPENAI_BATCH_SIZE=20

# Optional: max output tokens per request (default: 4096)
# OPENAI_MAX_TOKENS=4096

# Optional: request timeout in milliseconds (default: 120000)
# OPENAI_TIMEOUT_MS=120000

# ── architect command ──────────────────────────────────────────────────────────

# Optional: model to use for architecture generation (default: gpt-4o)
# OPENAI_ARCHITECT_MODEL=gpt-4o

# Optional: max output tokens for the architecture document (default: 16384)
# Increase if the document is truncated (you will see a warning).
# OPENAI_ARCHITECT_MAX_TOKENS=16384
